{
  "version": 2,
  "functions": {
    "api/download.py": { "runtime": "python3.12", "maxDuration": 30 },
    "api/info.py":     { "runtime": "python3.12", "maxDuration": 15 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)",     "dest": "/public/index.html" }
  ]
}
